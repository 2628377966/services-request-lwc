<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Support_Phone_Number__c</fullName>
    <description>Returns phone number for AU or NZ based on country selected on lead. Used in merge fields on email templates</description>
    <externalId>false</externalId>
    <formula>if (ISPICKVAL( CountryCode ,&quot;NZ&quot;),&quot;0800 478 483&quot;,&quot;1300 763 256&quot;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Support Phone Number</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
