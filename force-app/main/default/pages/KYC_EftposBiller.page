<apex:page applyBodyTag="false" applyHtmlTag="false" docType="html-5.0" showHeader="false" sidebar="false" controller="KYC_EftposBiller_Controller" action="{!init}" cache="false" standardStylesheets="false">
    <!-- Force recompile: Updated on 2025-10-01 12:00 PM -->
    <html lang="en">
        <head>
            
            <meta charset="utf-8" />
            <meta http-equiv="X-UA-Compatible" content="IE=edge" />
            <meta name="viewport" content="width=device-width, initial-scale=1" />
            <meta name="description" content="CSA Online" />
            <meta name="author" content="Ezidebit" />
            
            <apex:outputPanel rendered="{!isEzidebitBrand }" layout="none">
                <title>Ezidebit CSA Fees Structure</title>
                <link rel="icon" type="image/png" href="{!URLFOR($Resource.EzidebitKYC, 'image/CSAICON.png')}" />
            </apex:outputPanel>
            <apex:outputPanel rendered="{! !isEzidebitBrand }" layout="none">
